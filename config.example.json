{
  "ipset_name": "simple_blacklist",
  "control_socket": "/run/simple-blocker.sock",
  "window": "3h",
  "whitelist": ["203.0.113.4", "10.0.0.0/24", "192.168.1.10-192.168.1.40", "2001:db8::/32"],
  "blacklist": ["198.51.100.0/24"],
  "firewall": {
    "mode": "internal",
    "backend": "auto",
    "chains": ["INPUT", "DOCKER-USER"],
    "enforce_ipv6": false
  },
  "ban_schedule": [
    { "offenses": 2, "ban": "10m" },
    { "offenses": 3, "ban": "30m" },
    { "offenses": 5, "ban": "1h" },
    { "offenses": 7, "ban": "24h" }
  ],
  "sources": [
    {
      "type": "journal",
      "name": "ssh",
      "target": "ssh",
      "since": "-1d",
      "pattern": "Invalid user \\S+ from \\[?(?P<ip>[0-9a-fA-F:.]+)\\]?"
    }
  ]
}
