{
  "ipset_name": "simple_blacklist",
  "window": "3h",
  "firewall": {
    "backend": "auto",
    "chains": ["INPUT", "DOCKER-USER"]
  },
  "ban_schedule": [
    { "offenses": 2, "ban": "10m" },
    { "offenses": 3, "ban": "30m" },
    { "offenses": 5, "ban": "1h" },
    { "offenses": 7, "ban": "24h" }
  ],
  "sources": [
    {
      "type": "journal",
      "name": "ssh",
      "target": "ssh",
      "since": "-1d",
      "pattern": "Invalid user \\S+ from (?P<ip>\\d{1,3}(?:\\.\\d{1,3}){3})"
    }
  ]
}
